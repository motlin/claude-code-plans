{
	"name": "claude-code-plans",
	"version": "1.0.0",
	"description": "Persistent HTTP server that serves Claude Code plans with syntax highlighting and real-time updates",
	"type": "module",
	"scripts": {
		"dev": "tsx src/server.ts",
		"start": "node dist/server.js",
		"build": "tsc",
		"eslint": "eslint . --fix",
		"eslint:ci": "eslint . --format json --output-file eslint_report.json",
		"biome": "npx biome format --write .",
		"biome:ci": "npx biome format .",
		"typecheck": "tsc --noEmit -p tsconfig.check.json",
		"test": "vitest",
		"test:run": "vitest run"
	},
	"dependencies": {
		"@shikijs/markdown-it": "^4.0.1",
		"chokidar": "^5.0.0",
		"markdown-it": "^14.1.0",
		"shiki": "^4.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@eslint/js": "^10.0.1",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^25.3.3",
		"@typescript-eslint/eslint-plugin": "^8.56.0",
		"@typescript-eslint/parser": "^8.56.0",
		"eslint": "^10.0.2",
		"globals": "^17.3.0",
		"jiti": "^2.6.1",
		"tsx": "^4.19.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
